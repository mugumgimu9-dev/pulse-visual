package com.pulsevisual.client;

import net.fabricmc.api.ClientModInitializer;
import net.fabricmc.fabric.api.client.rendering.v1.HudRenderCallback;
import net.minecraft.client.MinecraftClient;

public class PulseVisualClient implements ClientModInitializer {
    @Override
    public void onInitializeClient() {
        // Регистрируем рендер интерфейса в обход тяжелых миксинов
        HudRenderCallback.EVENT.register((matrixStack, tickDelta) -> {
            MinecraftClient client = MinecraftClient.getInstance();
            
            // Проверяем, что игрок в мире и шрифты готовы
            if (client.player != null && client.textRenderer != null) {
                // Рисуем зелёную надпись в левом верхнем углу (X=10, Y=10)
                client.textRenderer.draw(matrixStack, "§a[Pulse Visual Active v1.0]", 10, 10, 0xffffff);
            }
        });
    }
}
